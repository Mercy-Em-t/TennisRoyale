# ─────────────────────────────────────────────────────────────
# Tennis Royale — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local (never commit .env.local to git)
# 2. Fill in your actual Firebase project credentials
# 3. Set VITE_DEV_MODE=false to enable real Firebase Auth
# ─────────────────────────────────────────────────────────────

# ── Firebase Project Config (from Firebase Console → Project Settings) ──
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_messaging_sender_id:web:your_app_id

# ── FCM (Firebase Cloud Messaging — Push Notifications) ──
# Get this from Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# ── App Mode ──
# Set to false to enable real Firebase Auth and Firestore
# Set to true to use mock data locally without Firebase credentials
VITE_DEV_MODE=false

# ── App Config ──
VITE_APP_NAME=Tennis Royale
VITE_APP_URL=https://your-project-id.web.app
