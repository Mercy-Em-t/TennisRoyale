rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function hasRole(role) {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isHost() {
      return hasRole('host') || isAdmin();
    }

    function isOfficial() {
      return hasRole('official') || isAdmin();
    }

    function isTournamentHost(tournamentId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.hostId
           == request.auth.uid;
    }

    function isParticipant(tournamentId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tournaments/$(tournamentId)/participants/$(request.auth.uid));
    }

    function isMatchParticipant() {
      return isSignedIn()
        && request.auth.uid in resource.data.participantsArray;
    }


    // ─────────────────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────────────────

    match /users/{uid} {
      // Anyone signed in can read user profiles (for match display)
      allow read: if isSignedIn();

      // Users can only write their OWN document
      // Admins can write any user document (for role elevation)
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────────────────
    // TOURNAMENTS
    // ─────────────────────────────────────────────────────────

    match /tournaments/{tournamentId} {
      // Public read — tournament discovery requires no auth
      allow read: if true;

      // Only hosts or admins can create tournaments
      allow create: if isHost()
        && request.resource.data.hostId == request.auth.uid;

      // Only the host of THIS tournament or an admin can update it
      allow update: if isTournamentHost(tournamentId) || isAdmin();
      allow delete: if isAdmin();


      // ── Participants sub-collection ──────────────────────
      match /participants/{uid} {
        allow read: if isSignedIn();

        // A player can add themselves; host or admin can add anyone
        allow create: if isOwner(uid) || isTournamentHost(tournamentId) || isAdmin();

        // Only host or admin can update participant records (stats, pool assignment)
        allow update: if isTournamentHost(tournamentId) || isAdmin()
          // Exception: the participant can update their own check-in status
          || (isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['checkedIn', 'checkedInAt']));

        allow delete: if isTournamentHost(tournamentId) || isAdmin();
      }


      // ── Matches sub-collection ───────────────────────────
      match /matches/{matchId} {
        // Public read — live scoreboard visible without login
        allow read: if true;

        // Only host or admin can create matches (generated by algorithm)
        allow create: if isTournamentHost(tournamentId) || isAdmin();

        // Updates allowed by:
        //   - Host / admin (full access)
        //   - Officials (dispute resolution, court assignment)
        //   - Participants (only their own submission field)
        allow update: if isTournamentHost(tournamentId) || isAdmin() || isOfficial()
          || (isMatchParticipant()
              && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['submissions', 'status', 'updatedAt'])
              // Players can only move status to 'live', never to 'completed' or 'disputed' directly
              // — that is enforced by the Cloud Function
              && request.resource.data.status in ['live', 'called']);

        allow delete: if isTournamentHost(tournamentId) || isAdmin();
      }


      // ── Brackets sub-collection ──────────────────────────
      match /brackets/{bracketId} {
        allow read: if true;
        allow write: if isTournamentHost(tournamentId) || isAdmin();
      }
    }


      // ── Audit Log sub-collection ─────────────────────────
      // Written exclusively by Cloud Functions (admin SDK bypasses rules).
      // Readable only by Officials and Admins — players cannot see
      // other players' raw submissions.
      match /auditLog/{entryId} {
        allow read:   if isOfficial() || isAdmin();
        allow create: if isAdmin();   // Cloud Functions use admin SDK (no rules apply)
        allow update, delete: if false;  // immutable — never editable
      }


    // ─────────────────────────────────────────────────────────
    // FINANCIAL LEDGER
    // ─────────────────────────────────────────────────────────

    match /ledger/{entryId} {
      // Only admins can read or write the ledger
      allow read, write: if isAdmin();
    }


    // ─────────────────────────────────────────────────────────
    // Deny everything else by default (Firestore default, but explicit)
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
